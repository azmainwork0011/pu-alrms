generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        String   @default("STUDENT") // SUPER_ADMIN, ADMIN, DEVELOPER, TEACHER, STUDENT, CR
  verified    Boolean  @default(false)     // Meta Verified badge
  status      String   @default("ACTIVE")  // ACTIVE, SUSPENDED, BANNED
  avatar      String?
  coverPhoto  String?
  rollNumber  String?
  batch       String?
  department  String?
  phone       String?
  bio         String?
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subjects       Subject[]
  assignments    Assignment[]
  submissions    Submission[]
  comments       Comment[]
  notifications  Notification[]
  announcements  Announcement[]
  chatMessages   ChatMessage[]
  quizAttempts   QuizAttempt[]
  quizProfile    QuizProfile?
  savedBooks     SavedBook[]
  battlesAsP1    BattleRoom[] @relation("BattlePlayer1")
  battlesAsP2    BattleRoom[] @relation("BattlePlayer2")
  cqProfile       CQProfile?
  cqFriends       CQFriend[]  @relation("UserFriends")
  cqFriendOf      CQFriend[]  @relation("FriendOf")
  cqBattlesP1     CQBattleSession[] @relation("CQBattleP1")
  cqBattlesP2     CQBattleSession[] @relation("CQBattleP2")
}

model Subject {
  id        String   @id @default(cuid())
  name      String
  code      String
  teacherId String
  batch     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher     User        @relation(fields: [teacherId], references: [id])
  assignments Assignment[]
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String
  subjectId   String
  type        String   @default("ASSIGNMENT")
  batch       String?
  deadline    DateTime
  fileUrl     String?
  status      String   @default("ACTIVE")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject     @relation(fields: [subjectId], references: [id])
  creator     User        @relation(fields: [createdBy], references: [id])
  submissions Submission[]
  comments    Comment[]
}

model Submission {
  id           String    @id @default(cuid())
  assignmentId String
  studentId    String
  fileName     String
  fileUrl      String?
  status       String    @default("SUBMITTED")
  marks        Float?
  feedback     String?
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    User       @relation(fields: [studentId], references: [id])
}

model Comment {
  id           String   @id @default(cuid())
  assignmentId String
  userId       String
  content      String
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("GENERAL")
  priority  String   @default("NORMAL")
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User @relation(fields: [createdBy], references: [id])
}

model ChatRoom {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("BATCH")
  batch         String?
  department    String?
  isPrivate     Boolean  @default(false)
  roomPassword  String?
  encryptionKey String   @default("")
  status        String   @default("ACTIVE")
  maxMembers    Int      @default(100)
  allowFiles    Boolean  @default(true)
  description   String?
  createdBy     String?
  lastActivity  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages ChatMessage[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  content    String
  messageType String  @default("TEXT")
  fileUrl    String?
  fileName   String?
  createdAt  DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id])
  user User     @relation(fields: [userId], references: [id])
}

model QuizCategory {
  id          String   @id @default(cuid())
  name        String
  department  String
  icon        String   @default("📚")
  description String?
  difficulty  String   @default("MEDIUM")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions QuizQuestion[] @relation("CategoryQuestions")
  attempts  QuizAttempt[]  @relation("CategoryAttempts")
  battles   BattleRoom[]
}

model QuizQuestion {
  id           String   @id @default(cuid())
  categoryId   String
  question     String
  optionA      String
  optionB      String
  optionC      String
  optionD      String
  correctOption String
  difficulty   String   @default("MEDIUM")
  points       Int      @default(10)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category QuizCategory @relation("CategoryQuestions", fields: [categoryId], references: [id])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  categoryId     String
  score          Int      @default(0)
  totalPoints    Int      @default(0)
  correctCount   Int      @default(0)
  totalQuestions Int      @default(0)
  accuracy       Float    @default(0)
  timeTaken      Int      @default(0)
  createdAt      DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id])
  category QuizCategory   @relation("CategoryAttempts", fields: [categoryId], references: [id])
}

model QuizProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  totalXP         Int      @default(0)
  dailyStreak     Int      @default(0)
  bestStreak      Int      @default(0)
  totalQuizzes    Int      @default(0)
  totalCorrect    Int      @default(0)
  totalQuestions  Int      @default(0)
  lastQuizDate    String?  // ISO date string (YYYY-MM-DD) for streak tracking
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model SavedBook {
  id          String   @id @default(cuid())
  userId      String
  bookId      String
  title       String
  authors     String
  coverUrl    String?
  category    String?
  language    String   @default("en")
  description String?
  infoLink    String?
  pdfLink     String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, bookId])
}

model BattleRoom {
  id              String   @id @default(cuid())
  player1Id       String
  player2Id       String?
  categoryId      String?
  status          String   @default("WAITING") // WAITING, IN_PROGRESS, COMPLETED
  totalQuestions  Int      @default(10)
  timePerQuestion Int      @default(15)
  player1Score    Int      @default(0)
  player2Score    Int      @default(0)
  player1Correct  Int      @default(0)
  player2Correct  Int      @default(0)
  winnerId        String?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  player1  User          @relation("BattlePlayer1", fields: [player1Id], references: [id])
  player2  User?         @relation("BattlePlayer2", fields: [player2Id], references: [id])
  category QuizCategory? @relation(fields: [categoryId], references: [id])
}

model CQProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  level            Int      @default(1)
  totalXP          Int      @default(0)
  currentLevelXP   Int      @default(0)
  xpToNextLevel    Int      @default(100)
  battlesWon       Int      @default(0)
  battlesLost      Int      @default(0)
  totalBattles     Int      @default(0)
  lessonsCompleted Int      @default(0)
  questionsAnswered Int     @default(0)
  correctAnswers   Int      @default(0)
  miniGamesPlayed  Int      @default(0)
  dailyStreak      Int      @default(0)
  bestStreak       Int      @default(0)
  lastActiveDate   String?
  title            String   @default("Code Novice")
  avatar           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model CQFriend {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User @relation("UserFriends", fields: [userId], references: [id])
  friend User @relation("FriendOf", fields: [friendId], references: [id])

  @@unique([userId, friendId])
}

model CQBattleSession {
  id              String   @id @default(cuid())
  player1Id       String
  player2Id       String?
  language        String?
  status          String   @default("WAITING")
  totalRounds     Int      @default(10)
  timePerRound    Int      @default(15)
  player1HP       Int      @default(100)
  player2HP       Int      @default(100)
  player1Score    Int      @default(0)
  player2Score    Int      @default(0)
  currentRound    Int      @default(0)
  winnerId        String?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  player1 User @relation("CQBattleP1", fields: [player1Id], references: [id])
  player2 User? @relation("CQBattleP2", fields: [player2Id], references: [id])
}
